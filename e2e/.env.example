# E2E env vars. Copy to .env.local (or rely on the existing .env.local) before running `pnpm test:e2e`.
#
# All e2e specs talk to a real Supabase project via the service-role admin client.
# They will create test rows tagged with E2E_TEST_PREFIX (default: "E2E_") so you can
# clean them up with: DELETE FROM sessions WHERE name LIKE 'E2E_%';
#
# IMPORTANT: by default this runs against the same project as the dev app
# (https://jeqxflutotkebgkgapti.supabase.co). To use a separate project, override
# E2E_SUPABASE_URL and E2E_SUPABASE_SERVICE_ROLE_KEY.

E2E_BASE_URL=http://localhost:3000

# Supabase — falls back to NEXT_PUBLIC_SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY from .env.local
# E2E_SUPABASE_URL=https://your-test-project.supabase.co
# E2E_SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Prefix applied to test data so cleanup is selective.
E2E_TEST_PREFIX=E2E_

# Comma-separated test users that the admin bootstrap will ensure exist.
E2E_TEST_USERS=e2e-aman@example.com,e2e-ravi@example.com,e2e-priya@example.com
